# Шаблон ключей. Скопировать в .env и заполнить (реальный .env в .gitignore).
# Загрузка в сессии:  set -a; . ./.env; set +a

# ── Cloudflare Pages (запасной хостинг) ──
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=dac5848359ab4d74798b9d572259981e
CLOUDFLARE_PAGES_PROJECT=bio-exam

# ── GitHub (основной хостинг) ──
